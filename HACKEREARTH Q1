#include <iostream>
#include <string>
using namespace std;
int main() {
    int n, k;
	cin >> n >> k;
	string bulbs;
	cin >> bulbs;
     // checking l 
    for (int l = 1; l <= n; l++) {
        int operations = 0;

        for (int i = 0; i < n; ) {
            if (bulbs[i] == '1') {
                operations++;
                i += l;
            } else {
                i++;
            }
        }

        if (operations <= k) {
            cout << l << endl;
            return 0;
        }
    }

    return 0;
}
